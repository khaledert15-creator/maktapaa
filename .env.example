# PostgreSQL is required. Do not use SQLite for this project.
DATABASE_URL=postgresql://postgres@127.0.0.1:55432/maktaba_dev

# Local API defaults
PORT=5001
SESSION_SECRET=replace-with-a-long-random-development-secret

# Comma-separated exact browser origins. Set this to the public HTTPS domain in production.
CORS_ORIGIN=http://localhost:5173
PUBLIC_SITE_URL=http://localhost:5173
API_URL=http://localhost:5001
TRUST_PROXY=0

# PostgreSQL pool
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000
DB_STATEMENT_TIMEOUT_MS=15000

# Local development stores generated WebP variants under uploads/.
STORAGE_PROVIDER=local
STORAGE_LOCAL_DIR=uploads

# Development mail writes the reset URL to structured local logs only.
EMAIL_PROVIDER=log
BUILD_VERSION=development
