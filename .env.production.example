# Copy to .env.production on the VPS. Never commit the populated file.
NODE_ENV=production
PORT=5001
POSTGRES_DB=maktaba
POSTGRES_USER=maktaba
POSTGRES_PASSWORD=replace-with-a-long-random-database-password
DATABASE_URL=postgresql://maktaba:replace-with-the-same-password@postgres:5432/maktaba
SESSION_SECRET=replace-with-at-least-32-random-characters
CORS_ORIGIN=https://maktabaa.com,https://www.maktabaa.com
PUBLIC_SITE_URL=https://maktabaa.com
API_URL=https://maktabaa.com/api
COOKIE_DOMAIN=.maktabaa.com
TRUST_PROXY=1
ACME_EMAIL=admin@maktabaa.com

# PostgreSQL pool (keep total pools below PostgreSQL max_connections).
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000
DB_STATEMENT_TIMEOUT_MS=15000
DB_APPLICATION_NAME=maktaba-api

# Cloudflare R2 / AWS S3 / S3-compatible object storage.
STORAGE_PROVIDER=s3
ALLOW_LOCAL_STORAGE_IN_PRODUCTION=false
S3_ENDPOINT=https://replace-account-id.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=maktaba-production
S3_ACCESS_KEY_ID=replace-me
S3_SECRET_ACCESS_KEY=replace-me
S3_PUBLIC_BASE_URL=https://cdn.maktabaa.com
S3_FORCE_PATH_STYLE=false

# Password reset email. Current production adapter uses Resend.
EMAIL_PROVIDER=resend
EMAIL_FROM=Maktaba Dot Com <no-reply@maktabaa.com>
RESEND_API_KEY=replace-me

# Optional error monitoring and release metadata.
SENTRY_DSN=
LOG_LEVEL=info
SLOW_REQUEST_MS=1000
BUILD_VERSION=replace-with-git-sha
